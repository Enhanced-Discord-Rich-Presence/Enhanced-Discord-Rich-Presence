{
  "manifest_version": 3,
  "name": "Enhanced Discord Rich Presence",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "2ab011842cebb01f81d1bafe44306ff18d7e2f82@temporary-addon"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["toast.html"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "permissions": ["tabs", "storage", "nativeMessaging"],
  "host_permissions": ["*://*.youtube.com/*", "*://music.youtube.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Monitor Settings"
  },
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["Activities/YoutubeMusic.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["Activities/Youtube.js"],
      "run_at": "document_idle"
    }
  ]
}