{
  "manifest_version": 3,
  "name": "Enhanced Discord Rich Presence",
  "version": "1.1.0",
  "icons": {
    "48": "src/icons/icon.png",
    "96": "src/icons/icon.png"
  },
    "browser_specific_settings": {
    "gecko": {
      "id": "enhanced_discord_rich_presence@enhncddrpc.org",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": ["tabs", "storage", "nativeMessaging"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://music.youtube.com/*",
    "*://github.com/*",
    "*://raw.githubusercontent.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Monitor Settings"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/icons/icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["Activities/YoutubeMusic.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["Activities/Youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}