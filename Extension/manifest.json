{
  "manifest_version": 3,
  "name": "Enhanced Discord Rich Presence",
  "version": "1.4.0",
  "key": "",
  "icons": {
    "48": "src/icons/icon.png",
    "96": "src/icons/icon.png"
  },
  "permissions": ["tabs", "storage", "nativeMessaging"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://music.youtube.com/*",
    "*://github.com/*",
    "*://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Monitor Settings"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/icons/icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["Activities/YoutubeMusic/data.js", "Activities/YoutubeMusic/handler.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["Activities/Youtube/data.js", "Activities/Youtube/handler.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*", "*://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}